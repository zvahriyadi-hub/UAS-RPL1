<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pendaftaran - NovaBuild</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:'DM Sans',sans-serif;
  background:#f7f4ee;
  min-height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  padding:20px;
}

.container{
  width:100%;
  max-width:550px;
  background:white;
  padding:40px;
  border-radius:20px;
  box-shadow:0 20px 50px rgba(0,0,0,.08);
}

.logo{
  text-align:center;
  margin-bottom:10px;
  font-family:'Playfair Display',serif;
  font-size:2rem;
  font-weight:900;
}

.logo span{
  color:#c8522a;
}

h2{
  text-align:center;
  margin-bottom:10px;
}

.desc{
  text-align:center;
  color:#666;
  margin-bottom:30px;
}

.form-group{
  margin-bottom:18px;
}

label{
  display:block;
  margin-bottom:8px;
  font-weight:500;
}

input,
select,
textarea{
  width:100%;
  padding:14px;
  border:1px solid #ddd;
  border-radius:10px;
  font-size:15px;
}

textarea{
  resize:vertical;
}

button{
  width:100%;
  padding:15px;
  background:#c8522a;
  color:white;
  border:none;
  border-radius:10px;
  font-size:16px;
  font-weight:600;
  cursor:pointer;
  transition:.3s;
}

button:hover{
  background:#a6401f;
}

.back{
  display:block;
  text-align:center;
  margin-top:20px;
  text-decoration:none;
  color:#c8522a;
  font-weight:500;
}
</style>
</head>
<body>

<div class="container">

  <div class="logo">
    Nova<span>Build</span>
  </div>

  <h2>Form Pendaftaran</h2>

  <p class="desc">
    Isi data berikut untuk memulai konsultasi gratis.
  </p>

  <form>

    <div class="form-group">
      <label>Nama Lengkap</label>
      <input type="text" required>
    </div>

    <div class="form-group">
      <label>Email</label>
      <input type="email" required>
    </div>

    <div class="form-group">
      <label>Nomor WhatsApp</label>
      <input type="tel" required>
    </div>

    <div class="form-group">
      <label>Jenis Layanan</label>
      <select required>
        <option value="">Pilih Layanan</option>
        <option>Website</option>
        <option>SEO</option>
        <option>Digital Marketing</option>
        <option>Aplikasi Mobile</option>
        <option>AI Integration</option>
      </select>
    </div>

    <div class="form-group">
      <label>Deskripsi Kebutuhan</label>
      <textarea rows="4"></textarea>
    </div>

    <button type="submit">
      Kirim Pendaftaran
    </button>

  </form>

  <a href="index.html" class="back">
    ← Kembali ke Beranda
  </a>

</div>

</body>
</html>